# Project Root Directory
HEADSCALE_HOME=/home/headscale/tail-headscale

# Database Configuration  
DB_PASSWORD=your_secure_db_password_here
AUTHELIA_DB_PASSWORD=authelia_secure_password

# OIDC Configuration
OIDC_CLIENT_SECRET=random_secret_32_chars_min
HEADSCALE_OIDC_SECRET=another_random_secret_32_chars
HEADPLANE_OIDC_SECRET=third_random_secret_32_chars

# Authelia Secrets
JWT_SECRET=jwt_secret_64_chars_minimum_length_required_for_security
SESSION_SECRET=session_secret_also_needs_good_length
STORAGE_ENCRYPTION_KEY=storage_key_32_chars_exactly
OIDC_HMAC_SECRET=oidc_hmac_secret_minimum_32_chars

# API Keys
HEADSCALE_ROOT_API_KEY=will_be_generated_after_headscale_start

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=noreply@company.vn
SMTP_PASSWORD=your_gmail_app_password

# Domain Configuration
BASE_DOMAIN=company.vn
HEADSCALE_DOMAIN=tailscale.company.vn
HEADPLANE_DOMAIN=admin.company.vn
AUTHELIA_DOMAIN=auth.company.vn
MONITOR_DOMAIN=monitor.company.vn
